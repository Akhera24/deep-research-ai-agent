# ============================================================================
# Deep Research AI Agent — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
# ============================================================================

# ── AI Model API Keys (Required) ──
ANTHROPIC_API_KEY=sk-ant-your-key-here
GOOGLE_API_KEY=your-google-api-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# ── Search API Keys (At least one required) ──
BRAVE_API_KEY=BSA-your-brave-key-here
SERPER_API_KEY=your-serper-key-here

# ── Database (Required) ──
DATABASE_URL=sqlite:///research.db

# ── Model Configuration (Optional) ──
# CLAUDE_MODEL=claude-opus-4-8
# GEMINI_MODEL=gemini-3.1-flash-lite
# OPENAI_MODEL=gpt-5.4-mini

# ── Research Settings (Optional) ──
# MAX_ITERATIONS=10
# MAX_FACTS=150
# COVERAGE_THRESHOLD=0.93

# ── Job API / deployment (Phase 3; all optional locally) ──
# ENVIRONMENT=production            # production refuses the default SECRET_KEY
# SECRET_KEY=<generate a long random value>   # salts IP hashes; REQUIRED in production
# CORS_ORIGINS=https://your-domain.example
# REPORT_RETENTION_DAYS=7
# MONTHLY_BUDGET_USD=40
# DAILY_SOFT_ALERT_USD=5
# PER_JOB_BUDGET_USD=1.0
# MAX_CONCURRENT_JOBS=3
# RATE_LIMIT_REPORTS_PER_HOUR=3
# ADMIN_BYPASS_TOKEN=<long random value; X-Admin-Token header skips rate limit + Turnstile>
# TURNSTILE_SITE_KEY=<real key; default is Cloudflare's always-pass TEST key>
# TURNSTILE_SECRET_KEY=<real key; default is Cloudflare's always-pass TEST key>
# TURNSTILE_EXPECTED_HOSTNAME=your-domain.example
# ALERT_WEBHOOK_URL=
# FORWARDED_ALLOW_IPS=100.64.0.0/10  # uvicorn env var — REQUIRED on Railway for real client IPs

# --- Disambiguation pre-flight (Phase C1, PLAN.md Rev 3.8/3.9) ---
# PREFLIGHT_TICKET_SECRET=<32+ random bytes — SET IN RAILWAY (Human TODO #6);
#   unset = boot-random fallback: restarts invalidate in-flight tickets (fail-safe)>
# D2 dominance-gate policy knobs (defaults shown; see config/settings.py):
# PREFLIGHT_TICKET_TTL_SECONDS=300
# PREFLIGHT_AUTO_MIN_MASS=3
# PREFLIGHT_AUTO_MAX_RUNNERUP=1
# PREFLIGHT_AUTO_SHARE=0.7
# PREFLIGHT_SINGLE_MIN_MASS=2
# PREFLIGHT_MAX_CANDIDATES=5
# PREFLIGHT_MAX_RESULTS=15
# PREFLIGHT_TIMEOUT_SECONDS=25
